---
import { Image } from "astro:assets";
import GithubIconBlack from "../../public/GithubIconBlack.svg";
import GitHubIconWhite from "../../public/GithubIconWhite.svg";
import WebsiteIconBlack from "../../public/WebsiteIconBlack.svg";
import WebsiteIconWhite from "../../public/WebsiteIconWhite.svg";

const { image, description, title, gitHub, liveSite, number } = Astro.props;
---

<div
  class="projectCard min-h-screen flex items-center px-6 md:px-16 py-20 relative z-10"
>
  <div class="w-full max-w-6xl mx-auto">
    <!-- Card -->
    <div class="border-4 border-dark drop-shadow-4xl bg-projectCardBg">
      <!-- Title bar -->
      <div
        class="flex items-center justify-between border-b-4 border-dark px-6 py-4 bg-primary"
      >
        <div class="flex items-center gap-4">
          <span class="font-mainFont text-5xl text-dark leading-none"
            >{number}</span
          >
          <h3 class="font-mainFont text-3xl md:text-5xl text-dark">{title}</h3>
        </div>
        <div class="flex gap-2">
          <span class="w-4 h-4 rounded-full bg-dark inline-block"></span>
          <span class="w-4 h-4 rounded-full bg-dark inline-block opacity-50"
          ></span>
          <span class="w-4 h-4 rounded-full bg-dark inline-block opacity-25"
          ></span>
        </div>
      </div>

      <!-- Body -->
      <div class="flex flex-col md:flex-row">
        <!-- Screenshot -->
        <div
          class="md:w-3/5 border-b-4 md:border-b-0 md:border-r-4 border-dark"
        >
          <Image
            loading="lazy"
            src={image}
            alt={title}
            class="w-full h-full object-cover object-top"
          />
        </div>

        <!-- Info -->
        <div class="md:w-2/5 flex flex-col justify-between p-8 gap-8">
          <p
            class="font-lightFont text-xl md:text-2xl text-dark leading-relaxed"
          >
            {description}
          </p>

          <div class="flex flex-col gap-3">
            <a
              href={liveSite}
              target="_blank"
              class="flex items-center justify-between gap-3 drop-shadow-3xl bg-appBackground border-dark border-4 px-4 py-3 font-black text-xl text-dark hover:translate-y-[-4px] transition-transform group"
            >
              <span>Live Site</span>
              <Image
                class="darkIcon"
                height="24"
                width="24"
                alt="live site"
                src={WebsiteIconBlack}
              />
              <Image
                class="whiteIcon"
                height="24"
                width="24"
                alt="live site"
                src={WebsiteIconWhite}
              />
            </a>

            <a
              href={gitHub}
              target="_blank"
              class="flex items-center justify-between gap-3 drop-shadow-3xl bg-appBackground border-dark border-4 px-4 py-3 font-black text-xl text-dark hover:translate-y-[-4px] transition-transform"
            >
              <span>GitHub</span>
              <Image
                class="darkIcon"
                height="24"
                width="24"
                alt="github"
                src={GithubIconBlack}
              />
              <Image
                class="whiteIcon"
                height="24"
                width="24"
                alt="github"
                src={GitHubIconWhite}
              />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const cards = document.querySelectorAll(".projectCard");
  gsap.set(cards, { opacity: 0, y: 60 });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          gsap.to(e.target, {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "back.out(1.4)",
          });
        }
      });
    },
    { threshold: 0.15 },
  );
  cards.forEach((c) => observer.observe(c));
</script>
